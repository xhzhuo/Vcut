  "version": "1.1",
  "source": "AI Agent——人工打标素材表",
  "source_url": "https://w6pz91x4e9.feishu.cn/wiki/NqltwIgFuiZZnRkF7APcLUVvnWe?sheet=hPUaFB",
  "exported_at": "2026-06-02",
  "categories": {
    "technical": {
      "label": "技术问题",
      "rules": [
        {
          "id": "T1",
          "name": "批量生成完整性",
          "severity": "high",
          "check": "batch_count == target_count",
          "description": "提交多条任务时，实际生成数量应等于目标数量"
        },
        {
          "id": "T2",
          "name": "音画同步",
          "severity": "high",
          "check": "abs(audio_end - video_end) < 1s",
          "description": "音频与视频时间轴一致，关键话术与画面切换对齐"
        },
        {
          "id": "T3",
          "name": "画面连续性",
          "severity": "high",
          "check": "no_freeze > 2s && no_deform",
          "description": "无连续静止画面、无画面冻结但音频继续、无画面变形"
        },
        {
          "id": "T4",
          "name": "音频质量",
          "severity": "high",
          "check": "no_distortion && no_silence_gap",
          "description": "无电音/杂音/乱码，音量均衡"
        }
      ]
    },
    "content": {
      "label": "内容问题",
      "rules": [
        {
          "id": "C1",
          "name": "话术转场",
          "severity": "medium",
          "check": "transition_smooth",
          "description": "转场前后话术逻辑连贯，节奏与口播匹配"
        },
        {
          "id": "C2",
          "name": "内容去重",
          "severity": "medium",
          "check": "no_duplicate_segments",
          "description": "无连续重复痛点描述，信息点分布均匀"
        },
        {
          "id": "C3",
          "name": "产品信息",
          "severity": "high",
          "check": "product_mention_count in [1,2] && !consecutive",
          "description": "产品名出现1-2次，不连续提及，与症状/成分对应明确"
        },
        {
          "id": "C4",
          "name": "逻辑连贯",
          "severity": "medium",
          "check": "logic_chain_complete",
          "description": "痛点→成分→效果逻辑链完整，口播与画面一致"
        }
      ]
    }
  },
  "brand_specific": {
    "xinkang": {
      "label": "新康",
      "focus": ["C3", "C1", "C4"],
      "common_issues": [
        "产品名缺失",
        "话术转接突兀",
        "成分症状对应不明确"
      ]
    },
    "baishi": {
      "label": "百事",
      "focus": ["T2", "T3", "T4"],
      "common_issues": [
        "音画不同步",
        "画面卡顿/静止",
        "音频电音/乱码"
      ]
    }
  },
